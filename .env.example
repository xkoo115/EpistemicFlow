# EpistemicFlow 环境变量示例
# 复制此文件为 .env 并修改相应值

# ============ 应用配置 ============
APP_ENVIRONMENT=development  # development, testing, production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
APP_API_PREFIX=/api

# ============ 数据库配置 ============
# SQLite (默认)
DB_URL=sqlite+aiosqlite:///./epistemicflow.db

# PostgreSQL 示例
# DB_URL=postgresql+asyncpg://user:password@localhost/epistemicflow

# MySQL 示例
# DB_URL=mysql+aiomysql://user:password@localhost/epistemicflow

DB_ECHO=false
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ============ 大模型配置 ============
# OpenAI GPT-4
LLM_GPT4__PROVIDER=openai
LLM_GPT4__API_KEY=your-openai-api-key-here
LLM_GPT4__BASE_URL=https://api.openai.com/v1
LLM_GPT4__MODEL_NAME=gpt-4
LLM_GPT4__TEMPERATURE=0.7
LLM_GPT4__MAX_TOKENS=2000
LLM_GPT4__TIMEOUT=30

# OpenAI GPT-3.5
LLM_GPT35__PROVIDER=openai
LLM_GPT35__API_KEY=your-openai-api-key-here
LLM_GPT35__MODEL_NAME=gpt-3.5-turbo
LLM_GPT35__TEMPERATURE=0.8

# Anthropic Claude
LLM_CLAUDE__PROVIDER=anthropic
LLM_CLAUDE__API_KEY=your-anthropic-api-key-here
LLM_CLAUDE__MODEL_NAME=claude-3-opus-20240229
LLM_CLAUDE__TEMPERATURE=0.7

# DeepSeek
LLM_DEEPSEEK__PROVIDER=deepseek
LLM_DEEPSEEK__API_KEY=your-deepseek-api-key-here
LLM_DEEPSEEK__BASE_URL=https://api.deepseek.com
LLM_DEEPSEEK__MODEL_NAME=deepseek-chat
LLM_DEEPSEEK__TEMPERATURE=0.8

# Ollama (本地)
LLM_OLLAMA__PROVIDER=ollama
LLM_OLLAMA__BASE_URL=http://localhost:11434
LLM_OLLAMA__MODEL_NAME=llama2
LLM_OLLAMA__TEMPERATURE=0.8
LLM_OLLAMA__TIMEOUT=60

# ============ 默认配置 ============
DEFAULT_LLM=gpt4
WORKFLOW_TIMEOUT=3600
CHECKPOINT_INTERVAL=60

# ============ 其他配置 ============
# 日志级别
LOG_LEVEL=INFO

# 缓存配置
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# 文件存储
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE=10485760  # 10MB