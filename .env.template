# ============================================================================
# EpistemicFlow 环境配置文件
# ============================================================================
#
# 使用说明:
#   1. 复制此文件为 .env: cp .env.template .env (Linux/Mac) 或 copy .env.template .env (Windows)
#   2. 根据您使用的大模型，配置对应的 API Key 和 URL
#   3. 设置 DEFAULT_LLM 为您要使用的默认模型
#
# 支持的大模型:
#   - DeepSeek (推荐，性价比高)
#   - OpenAI GPT-4 / GPT-3.5
#   - Anthropic Claude
#   - Ollama (本地部署，免费)
#
# ============================================================================

# ============ 应用配置 ============
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://127.0.0.1:5173"]
APP_API_PREFIX=/api

# ============ 数据库配置 ============
# SQLite (默认，无需额外配置)
DB_URL=sqlite+aiosqlite:///./epistemicflow.db
DB_ECHO=false
DB_POOL_SIZE=5

# PostgreSQL (生产环境推荐)
# DB_URL=postgresql+asyncpg://user:password@localhost:5432/epistemicflow

# ============ 大模型配置 ============
# ============================================================================
# 请选择一个模型配置，并设置 DEFAULT_LLM 为对应的模型名称
# ============================================================================

# ----------------------------------------------------------------------------
# DeepSeek 配置 (推荐)
# 性价比高，中文支持好，适合科研场景
# 获取 API Key: https://platform.deepseek.com/
# ----------------------------------------------------------------------------
LLM_DEEPSEEK__PROVIDER=deepseek
LLM_DEEPSEEK__API_KEY=your-deepseek-api-key-here
LLM_DEEPSEEK__BASE_URL=https://api.deepseek.com
LLM_DEEPSEEK__MODEL_NAME=deepseek-chat
LLM_DEEPSEEK__TEMPERATURE=0.8
LLM_DEEPSEEK__MAX_TOKENS=4096
LLM_DEEPSEEK__TIMEOUT=60

# ----------------------------------------------------------------------------
# OpenAI GPT-4 配置
# 最强大的模型，适合复杂任务
# 获取 API Key: https://platform.openai.com/
# ----------------------------------------------------------------------------
# LLM_GPT4__PROVIDER=openai
# LLM_GPT4__API_KEY=your-openai-api-key-here
# LLM_GPT4__BASE_URL=https://api.openai.com/v1
# LLM_GPT4__MODEL_NAME=gpt-4-turbo-preview
# LLM_GPT4__TEMPERATURE=0.7
# LLM_GPT4__MAX_TOKENS=4096
# LLM_GPT4__TIMEOUT=60

# ----------------------------------------------------------------------------
# OpenAI GPT-3.5 配置
# 速度快，成本低
# ----------------------------------------------------------------------------
# LLM_GPT35__PROVIDER=openai
# LLM_GPT35__API_KEY=your-openai-api-key-here
# LLM_GPT35__BASE_URL=https://api.openai.com/v1
# LLM_GPT35__MODEL_NAME=gpt-3.5-turbo
# LLM_GPT35__TEMPERATURE=0.8
# LLM_GPT35__MAX_TOKENS=2048

# ----------------------------------------------------------------------------
# Anthropic Claude 配置
# 擅长长文本理解和分析
# 获取 API Key: https://console.anthropic.com/
# ----------------------------------------------------------------------------
# LLM_CLAUDE__PROVIDER=anthropic
# LLM_CLAUDE__API_KEY=your-anthropic-api-key-here
# LLM_CLAUDE__BASE_URL=https://api.anthropic.com
# LLM_CLAUDE__MODEL_NAME=claude-3-opus-20240229
# LLM_CLAUDE__TEMPERATURE=0.7
# LLM_CLAUDE__MAX_TOKENS=4096
# LLM_CLAUDE__TIMEOUT=60

# ----------------------------------------------------------------------------
# Ollama 配置 (本地部署，免费)
# 需要先安装 Ollama: https://ollama.ai/
# 然后拉取模型: ollama pull llama2
# ----------------------------------------------------------------------------
# LLM_OLLAMA__PROVIDER=ollama
# LLM_OLLAMA__BASE_URL=http://localhost:11434
# LLM_OLLAMA__MODEL_NAME=llama2
# LLM_OLLAMA__TEMPERATURE=0.8
# LLM_OLLAMA__MAX_TOKENS=2048
# LLM_OLLAMA__TIMEOUT=120

# ============ 默认模型设置 ============
# 设置为您要使用的模型名称 (deepseek, gpt4, gpt35, claude, ollama)
DEFAULT_LLM=deepseek

# ============ 工作流配置 ============
WORKFLOW_TIMEOUT=3600
CHECKPOINT_INTERVAL=60

# ============ 其他配置 ============
LOG_LEVEL=INFO
STORAGE_PATH=./storage
MAX_UPLOAD_SIZE=10485760
